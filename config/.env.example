# ============================================
# 微信公众号全自动发布智能体 - 环境变量配置模板
# 复制此文件为 .env 并填入真实值
# ============================================

# 微信公众号配置
WECHAT_APP_ID=your_app_id_here
WECHAT_APP_SECRET=your_app_secret_here

# AI模型API配置
AI_API_KEY=your_api_key_here
AI_API_BASE=https://api.openai.com/v1
AI_MODEL=gpt-4

# 日志级别
LOG_LEVEL=INFO

# 运行环境
ENVIRONMENT=development
